# Backend Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=./database.db

# Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
# 100MB in bytes

# CORS
# Comma-separated production allowlist. In development, localhost and private
# network HTTP origins are also allowed so LAN device testing works.
CORS_ORIGIN=http://192.168.1.215:8081,http://localhost:8080,http://localhost:8081,http://localhost:5173

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:5173

# External Billing/Purchasing Site
EXTERNAL_BILLING_URL=https://billing.example.com
# This is where users will be directed to purchase/manage subscriptions

# Work Hours (default)
DEFAULT_WORK_START=8
DEFAULT_WORK_END=18

# Pricing Configuration
PRICE_PER_PRINTER=10.00
PRICE_PER_ADDITIONAL_USER=0.25

# Stripe Configuration (optional - if using Stripe for webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SAML Configuration (optional - for institutional SSO)
SAML_ENTRY_POINT=https://idp.example.edu/saml/sso
SAML_ISSUER=print-farm-orchestrator
SAML_CALLBACK_URL=https://your-domain.com/api/auth/saml/callback
SAML_CERT=path/to/idp-cert.pem

# Slicer Paths (for CLI integration)
SLICER_CURA_CLI=/path/to/CuraEngine
SLICER_PRUSA_CLI=/path/to/prusa-slicer-console
SLICER_ORCA_CLI=/path/to/orcaslicer-cli
SLICER_BAMBU_CLI=/path/to/bambu-studio-cli
SLICER_PREFORM_CLI=/path/to/PreFormServer

# Dev-only: bypass rate limiting (never enable in production)
DEV_RATE_LIMIT_BYPASS=false
